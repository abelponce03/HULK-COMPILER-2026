function log(func) {
    function(x: Number) {
        print(999);
        func(x);
    };
}

function memoize(limit: Number) {
    function(func) {
        function(x: Number) {
            if (x > limit) {
                print(888);
                0;
            } else {
                func(x);
            };
        };
    };
}

@memoize(100)
@log
function fib(n: Number): Number =>
    if (n <= 1) n else fib(n - 1) + fib(n - 2);

print(fib(5));
print(fib(150));
